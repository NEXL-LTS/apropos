{
  "version": 1,
  "hooks": {
    "postToolUse": [
      {
        "type": "command",
        "matcher": "view",
        "command": "agent-apropos hook pre",
        "timeoutSec": 10
      },
      {
        "type": "command",
        "matcher": "create|edit",
        "command": "agent-apropos hook pre",
        "timeoutSec": 10
      },
      {
        "type": "command",
        "matcher": "create|edit",
        "command": "agent-apropos hook post",
        "timeoutSec": 10
      }
    ]
  }
}